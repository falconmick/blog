{
	"compatibility_date": "2026-05-15",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "astro-blog",
	"main": "@astrojs/cloudflare/entrypoints/server",
  "workers_dev": false,
  "preview_urls": true,
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}
