---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <h1><a href="/">My Coding Life</a></h1>
      <p>Michael's personal site and blog</p>
      <nav>
        <a href="/">Home</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p></p>
    </footer>
  </body>
</html>
