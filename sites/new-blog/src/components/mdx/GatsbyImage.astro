---
import type { ImageMetadata } from 'astro:assets';
import OptimizedImage from '../OptimizedImage.astro';

interface Props {
  alt?: string;
  image?: ImageMetadata | string;
  title?: string;
}

const { alt = '', image = '', title } = Astro.props;
---
{
  image && (
    <OptimizedImage
      src={image}
      alt={alt}
      title={title}
      layout="constrained"
      widths={[320, 480, 640, 736]}
      quality={70}
      fit="contain"
      sizes="(min-width: 1024px) 736px, calc(100vw - 2rem)"
    />
  )
}
