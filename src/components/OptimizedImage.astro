---
import { Image, type ImageMetadata } from "astro:assets";

interface Props {
  src?: ImageMetadata | string;
  alt: string;
  title?: string;
  class?: string;
  layout?: "constrained" | "fixed" | "full-width" | "none";
  widths?: number[];
  height?: number;
  quality?: number;
  fit?: "contain" | "cover" | "fill" | "none" | "scale-down";
  loading?: "eager" | "lazy";
  decoding?: "async" | "auto" | "sync";
  priority?: boolean;
  sizes?: string;
}

const {
  src,
  alt,
  title,
  class: className,
  layout = "constrained",
  widths,
  height,
  quality = 70,
  fit = "contain",
  loading,
  decoding = "async",
  priority,
  sizes,
} = Astro.props;

const isLocalRasterImage =
  src && typeof src === "object" && "src" in src && src.format !== "svg";
---

{
  isLocalRasterImage ? (
    <Image
      src={src}
      alt={alt}
      title={title}
      class={className}
      layout={layout}
      widths={widths}
      height={height}
      quality={quality}
      format="webp"
      fit={fit}
      loading={loading}
      decoding={decoding}
      priority={priority}
      sizes={sizes}
    />
  ) : (
    src && (
      <img
        src={typeof src === "string" ? src : src.src}
        alt={alt}
        title={title}
        class:list={[className, "svg-img"]}
        loading={loading}
        decoding={decoding}
        style={{ height: height ? `${height}px` : undefined }}
      />
    )
  )
}
